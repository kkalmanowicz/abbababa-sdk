{
  "name": "@abbababa/sdk",
  "version": "1.1.2",
  "type": "module",
  "description": "TypeScript SDK for the Abbababa A2A Settlement Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./wallet": {
      "import": "./dist/wallet/index.js",
      "types": "./dist/wallet/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.2",
    "semver": "^7.6.3",
    "viem": "^2.45.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abba-Baba/abbababa-sdk"
  },
  "homepage": "https://github.com/Abba-Baba/abbababa-sdk#readme",
  "keywords": [
    "a2a",
    "agent",
    "commerce",
    "escrow",
    "base",
    "polygon",
    "usdc",
    "settlement",
    "mcp"
  ],
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "bugs": {
    "url": "https://github.com/Abba-Baba/abbababa-sdk/issues"
  }
}
